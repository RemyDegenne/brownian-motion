lemma _root_.Filter.Tendsto.eventually_const_le_of_nhdsWithin_Iio
    {κ : Type*} [LinearOrder κ] [TopologicalSpace κ] [OrderTopology κ]
    {u : ℕ → κ} {s t : κ}
    (hu : Tendsto u atTop (nhdsWithin t (Set.Iio t))) (hst : s < t) :
