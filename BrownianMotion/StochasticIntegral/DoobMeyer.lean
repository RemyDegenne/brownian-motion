    {κ Ω' : Type*} [ConditionallyCompleteLinearOrderBot κ] [TopologicalSpace κ]
    [OrderTopology κ] [MeasurableSpace κ] [BorelSpace κ] [SecondCountableTopology κ]
    [PseudoMetrizableSpace κ] {mΩ' : MeasurableSpace Ω'} {P' : Measure Ω'}
