    (hu_tendsto : Tendsto u atTop (nhdsWithin t (Set.Iio t)))
    {C : ℝ} (hC_nonneg : 0 ≤ C)
    (hbound_horizon : ∀ᵐ ω ∂P', ∀ r ∈ Set.Icc (⊥ : κ) t, ‖N r ω‖ ≤ C)
    (hjump_int : Integrable (fun ω => N t ω - Function.leftLim (N · ω) t) P') :
