      hN_cadlag hN_pred hN_var hτ ht hu_lt hu_tendsto hC_nonneg hbound_horizon
  filter_upwards [hstopped] with ω hω_stopped hτt
  have hterminal :
      stoppedProcess (fun i ↦ {ω' : Ω' | (⊥ : κ) < τ ω'}.indicator (N i)) τ t ω =
        N t ω := by
    have hbotτ : (⊥ : κ) < τ ω :=
