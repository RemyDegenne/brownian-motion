    (hN_bound : ∀ᵐ ω ∂P', ∀ s ∈ Set.Icc (⊥ : κ) t, ‖N s ω‖ ≤ C)
    (hN_cont : ∀ ω, ContinuousOn (N · ω) (Set.Icc (⊥ : κ) t))
    (hN_var : ∀ ω, BoundedVariationOn (N · ω) (Set.Icc (⊥ : κ) t))
    (hN_sq_int : Integrable (fun ω => N t ω ^ 2) P')
    (hN_sq_zero : ∫ ω, N t ω ^ 2 ∂P' = 0) :
