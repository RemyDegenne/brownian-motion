    (ht : (⊥ : κ) < t) {u : ℕ → κ} (hu_lt : ∀ n, u n < t)
    (hu_tendsto : Tendsto u atTop (nhdsWithin t (Set.Iio t)))
    {C : ℝ} (hC_nonneg : 0 ≤ C)
