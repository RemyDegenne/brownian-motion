    {t : κ} (ht : (⊥ : κ) < t)
    (hbot_prev : ∀ r : κ, r < t → r ≤ (⊥ : κ)) :
    N t =ᵐ[P'] 0 := by
  exact hN.eq_zero_of_predictable_left_isolated_of_previous hN_pred ht ht hbot_prev
